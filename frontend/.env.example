# Cortify AI Frontend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control

# ======================
# REQUIRED - BFF Pattern Configuration
# ======================

# P2P Backend URL (handles auth + proxies to AI Backend)
# This is the main API endpoint for all frontend requests
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3001

# Authentication Base URLs (for Electron OAuth flow)
AUTH_BASE_URL_DEV=https://app.cortify.ai
AUTH_BASE_URL_PROD=https://app.cortify.ai

# ======================
# DEVELOPMENT ONLY
# These are NOT bundled in production builds
# Read by Electron main.js for local dev convenience
# ======================

# Deepgram API Key for speech-to-text (dev fallback)
# In production, all API calls go through backend proxy
# DEEPGRAM_API_KEY=your_deepgram_key_here

# ======================
# DEPRECATED - DO NOT USE
# All API keys are now stored on the P2P Backend
# Frontend uses backend proxy for all API calls
# ======================
# NEXT_PUBLIC_GROQ_API_KEY - REMOVED (use /api/groq/chat proxy)
# NEXT_PUBLIC_GEMINI_API_KEY - REMOVED (use /api/gemini/generate proxy)
# NEXT_PUBLIC_OPENAI_API_KEY - REMOVED (use backend proxy)
# NEXT_PUBLIC_DEEPGRAM_API_KEY - REMOVED (use /api/deepgram/token proxy)
# NEXT_PUBLIC_ANALYSIS_API_URL - REMOVED (use NEXT_PUBLIC_BACKEND_API_URL)
